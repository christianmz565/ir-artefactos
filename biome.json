{
  "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!node_modules",
      "!.next",
      "!dist",
      "!build",
      "!storybook-static",
      "!src/*-types.ts",
      "!**/importMap.js",
      "!src/migrations"
    ]
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    },
    "formatter": {
      "enabled": true
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "javascript": {
    "globals": ["React", "JSX", "storybook", "args", "globals"]
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",

      "suspicious": {
        "noUnknownAtRules": "off",
        "noConsole": "warn",
        "noExplicitAny": "warn",
        "noArrayIndexKey": "off",
        "noShadowRestrictedNames": "error"
      },

      "correctness": {
        "noUnusedVariables": "error",
        "noUnusedImports": "error",
        "useExhaustiveDependencies": "error"
      },

      "style": {
        "useConst": "error",
        "noNegationElse": "warn",
        "useImportType": "error"
      }
    },

    "domains": {
      "next": "recommended",
      "react": "recommended"
    }
  },

  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on",
        "useSortedProperties": "on"
      }
    }
  }
}
